# Brief nach Berlin — Environment Variables Template
# Copy to .env.local and fill in your keys. This file is safe to commit.

# Mistral AI — letter generation + voice transcription (Voxtral)
# Get your key at: https://console.mistral.ai → API Keys → Create new key
MISTRAL_API_KEY=

# OpenAI — moderation API only (content safety checks)
OPENAI_API_KEY=

# Brevo (email delivery)
# Get your key at: https://app.brevo.com → Settings → SMTP & API → API Keys
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# Langfuse (optional — observability for letter generation; app runs without these)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com
