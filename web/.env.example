# Brief nach Berlin — Environment Variables Template
# Copy to .env.local and fill in your keys. This file is safe to commit.

# Mistral AI — letter generation, content moderation, and voice transcription (Voxtral)
# Models in use (source of truth: web/src/lib/mistral.ts MISTRAL_MODELS):
#   - mistral-medium-latest        (letter generation)
#   - mistral-moderation-latest    (input + output moderation)
#   - voxtral-mini-latest          (audio transcription, Voxtral Mini Transcribe 2.0)
# Get your key at: https://console.mistral.ai → API Keys → Create new key
# DSGVO note: in the Mistral console, verify that "Use my data to train models"
# is disabled for this workspace (Settings → Data sharing).
MISTRAL_API_KEY=

# Brevo (transactional email delivery — single send per request, no list)
# Get your key at: https://app.brevo.com → Settings → SMTP & API → API Keys
# DSGVO note: in the Brevo dashboard, disable Open & Click tracking
# (Senders, Domains & Dedicated IPs → Tracking) — otherwise Brevo injects
# a tracking pixel into outgoing mails, which would require user consent.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# Feature-Flag für den automatisierten 3-Tage-Followup nach jeder Brief-Erstellung.
# Nur wenn exakt auf "true" gesetzt, wird via Brevo `scheduledAt` (~72h später)
# eine zweite Mail eingequeut. Erlaubt schnelle Notabschaltung ohne Deploy.
BREVO_FOLLOWUP_ENABLED=
