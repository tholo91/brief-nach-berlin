# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# backlog follow-up campaign artefacts (May 2026)
.backlog-token.txt
.backlog-recipients.csv

# transient outputs from one-off prompt-iteration test scripts
/scripts/*-output.json

# data pipeline — raw source files are regenerated by build scripts
# generated JSONs in data/ (e.g. plz-wahlkreis-mapping.json) ARE committed
/data/raw/*
# Exception: small Stadtstaat polygon file from bundestag.de (~150KB, stable
# per BTW cycle). Committed so build:plz works on a fresh checkout.
!/data/raw/btw25-stadtstaaten-polygons.json
